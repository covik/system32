{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "production:preview": {
      "dependsOn": ["build", "^production:preview"],
      "cache": false
    },
    "production:refresh": {
      "dependsOn": ["build", "^production:refresh"],
      "cache": false
    },
    "production:deploy": {
      "dependsOn": ["build", "^production:deploy"],
      "cache": false
    }
  }
}
