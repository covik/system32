{
  "image": "ghcr.io/covik/system32/devcontainer:latest@sha256:412765882a239c2d2ce957557c722e6c3511ea93ea5c6d6b8c43625de32178bf",
  "postCreateCommand": "yarn install --frozen-lockfile",
  "postAttachCommand": "echo '{}' > ~/.docker/config.json",
  "mounts": [
    "source=jetbrains-config-${localWorkspaceFolderBasename},target=/home/developer/.config/JetBrains,type=volume",
    "source=jetbrains-data-${localWorkspaceFolderBasename},target=/home/developer/.local/share/JetBrains,type=volume",
    "source=jetbrains-cache-${localWorkspaceFolderBasename},target=/home/developer/.cache/JetBrains,type=volume",
    "source=jetbrains-dist,target=/home/developer/.cache/JetBrains/RemoteDev/dist,type=volume",
    "source=pulumi-home,target=/home/developer/.pulumi,type=volume",
    "source=yarn-classic-cache,target=/home/developer/.cache/.yarn,type=volume"
  ],
  "containerEnv": {
    "KUBECONFIG": "${containerWorkspaceFolder}/kubeconfig.yml"
  }
}
