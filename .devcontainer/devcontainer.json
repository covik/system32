{
	"build": {
		"dockerfile": "Dockerfile",
		"target": "dev"
	},
	"postCreateCommand": "pnpm install --frozen-lockfile",
	"containerEnv": {
		"KUBECONFIG": "${containerWorkspaceFolder}/kubeconfig.yml"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"biomejs.biome",
				"editorconfig.editorconfig"
			]
		}
	}
}