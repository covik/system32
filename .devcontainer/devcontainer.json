{
  "build": {
    "dockerfile": "Dockerfile",
    "target": "dev"
  },
  "postCreateCommand": "yes | pnpm install --frozen-lockfile",
  "postAttachCommand": "echo '{}' > ~/.docker/config.json",
  "mounts": ["source=pulumi-home,target=/home/developer/.pulumi,type=volume"],
  "containerEnv": {
    "KUBECONFIG": "${containerWorkspaceFolder}/kubeconfig.yml"
  }
}
