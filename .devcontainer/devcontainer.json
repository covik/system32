{
	"dockerFile": "Dockerfile",
	"postCreateCommand": "pnpm install --frozen-lockfile --ignore-scripts",
	"containerEnv": {
		"KUBECONFIG": "${containerWorkspaceFolder}/kubeconfig.yml"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"biomejs.biome",
				"editorconfig.editorconfig",
				"github.vscode-github-actions"
			]
		}
	}
}
