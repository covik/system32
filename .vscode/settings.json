{
	"files.readonlyInclude": {
		"**/dist/**": true,
		"**/node_modules/**": true
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit",
		"source.organizeImports.biome": "explicit"
	},
	"json.schemaDownload.trustedDomains": {
		"https://biomejs.dev/schemas/2.4.11/schema.json": true,
		"https://docs.renovatebot.com/renovate-schema.json": true,
		"https://turborepo.dev/schema.json": true
	},
	"github-actions.workflows.pinned.workflows": [".github/workflows/ci.yaml"]
}
